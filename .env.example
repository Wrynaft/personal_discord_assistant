DISCORD_TOKEN="the_token"
GROQ_API_KEY="your_groq_api_key_here"
# Model to use (e.g., "llama-3.3-70b-versatile", "llama-3.1-8b-instant")
GROQ_MODEL="llama-3.3-70b-versatile"
NEWS_API_KEY="your_newsapi_key_here"
# Channel ID where daily news will be posted at 9am MYT (right-click channel > Copy Channel ID)
NEWS_CHANNEL_ID="your_channel_id_here"
# PostgreSQL connection for analytics
DATABASE_URL="postgresql://discord:discord_analytics_2026@localhost:5432/discord_analytics"
